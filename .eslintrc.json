{
    "env": {
        "browser": true,
        "node": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:node/recommended",
        "prettier"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "globals": {
        "Web3": "readonly"
    },
    "rules": {
        "no-unused-vars": [
            "warn"
        ],
        "no-console": "off",
        "node/no-unsupported-features/es-syntax": "off"
    }
}